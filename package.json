        "chart.js": "^4.5.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ejs": "^3.1.9",
        "express": "^4.18.2",
        "font-awesome": "^4.7.0",
        "pdfmake": "^0.2.7",
        "pg": "^8.11.1",
        "pg-hstore": "^2.3.4",
        "puppeteer": "^24.41.0",
        "react": "^18.2.0",
        "react-chartjs-2": "^5.3.1",
        "react-dom": "^18.2.0",
        "react-minimal-pie-chart": "^9.1.2",
        "react-router-dom": "^6.14.1",
        "recharts": "^3.8.1",
        "sequelize": "^6.32.1"
    },
    "devDependencies": {
        "@babel/core": "^7.22.5",
        "@babel/preset-env": "^7.22.5",
        "@babel/preset-react": "^7.22.5",
