{
    "name": "sistema-gestion-productos",
    "version": "1.0.0",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "build": "webpack --mode production",
        "build:dev": "webpack --mode development --watch",
        "build:tienda": "ng build tienda-productos-angular",
        "serve:tienda": "ng serve tienda-productos-angular --port 4201",
        "build:css": "npx tailwindcss -i ./src/client/styles.css -o ./public/css/tailwind.css --watch",
        "migrate": "npx sequelize-cli db:migrate",
        "seed": "npx sequelize-cli db:seed:all",
        "dev:tienda": "vite --config vite.config.mjs"
    },
    "dependencies": {
        "@angular/animations": "^17.3.12",
        "@angular/common": "^17.3.12",
        "@angular/compiler": "^17.3.12",
        "@angular/core": "^17.3.12",
        "@angular/forms": "^17.3.12",
        "@angular/platform-browser": "^17.3.12",
        "@angular/router": "^17.3.12",
        "tailwindcss": "^3.4.19",
        "axios": "^1.4.0",
        "bcryptjs": "^2.4.3",
        "chart.js": "^4.5.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ejs": "^3.1.9",
        "express": "^4.18.2",
        "font-awesome": "^4.7.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "pdfmake": "^0.2.7",
        "pg": "^8.11.1",
        "pg-hstore": "^2.3.4",
        "puppeteer": "^24.41.0",
        "react": "^18.2.0",
        "react-chartjs-2": "^5.3.1",
        "react-dom": "^18.2.0",
        "react-minimal-pie-chart": "^9.1.2",
        "react-router-dom": "^6.14.1",
        "recharts": "^3.8.1",
        "rxjs": "^7.8.1",
        "sequelize": "^6.32.1"
    },
    "devDependencies": {
        "@analogjs/vite-plugin-angular": "^2.4.10",
        "@angular-devkit/build-angular": "^17.3.17",
        "@angular/cli": "^17.3.12",
        "@angular/compiler-cli": "^17.3.12",
        "@babel/core": "^7.22.5",
        "@babel/preset-env": "^7.22.5",
        "@babel/preset-react": "^7.22.5",
        "autoprefixer": "^10.4.14",
        "babel-loader": "^9.1.2",
        "css-loader": "^7.1.4",
